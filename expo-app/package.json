{
  "name": "expo-app",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "expo": "~57.0.4",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.2",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.4",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~57.0.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "bash scripts/start-expo-go.sh",
    "start:tunnel": "expo start --go --tunnel -c",
    "start:lan": "REACT_NATIVE_PACKAGER_HOSTNAME=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1) expo start --go --offline -c",
    "android": "bash scripts/start-expo-go.sh --android",
    "ios": "EXPO_OFFLINE=1 expo start --go --ios -c",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "version:print": "node -e \"const a=require('./app.json'); const p=require('./package.json'); console.log('app',a.expo.version,'pkg',p.version,'ios',a.expo.ios.buildNumber,'android',a.expo.android.versionCode)\""
  },
  "private": true
}
